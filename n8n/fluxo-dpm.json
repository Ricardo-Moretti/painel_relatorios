{
  "name": "DPM - Verificação Diária (Autônomo)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 5 * * 1-5"
            }
          ]
        }
      },
      "id": "cron-trigger",
      "name": "⏰ Todo dia 5h (seg-sex)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "// ==========================================\n// VERIFICAÇÃO DPM — AUTÔNOMO (sem backend)\n// Acessa a pasta de rede diretamente\n// ==========================================\n\nconst fs = require('fs');\n\n// Configuração\nconst DPM_PATH = '//192.168.109.228/dtf/dpmext/salva';\nconst DPM_PREFIX = 'DLR2JD_DPMEXT_D_201077_';\n\n// Data de ontem (DPM roda às 23h)\nconst ontem = new Date();\nontem.setDate(ontem.getDate() - 1);\nconst ano = ontem.getFullYear();\nconst mes = String(ontem.getMonth() + 1).padStart(2, '0');\nconst dia = String(ontem.getDate()).padStart(2, '0');\nconst dataArquivo = `${ano}${mes}${dia}`;\nconst dataFormatada = `${dia}/${mes}/${ano}`;\nconst dataISO = `${ano}-${mes}-${dia}`;\n\ntry {\n  const files = fs.readdirSync(DPM_PATH);\n  const encontrados = files.filter(f => f.startsWith(DPM_PREFIX) && f.includes(dataArquivo));\n\n  if (encontrados.length > 0) {\n    const ultimo = encontrados.sort().pop();\n    const horario = ultimo.match(/_(\\d{6})\\.DPM$/);\n    const horaStr = horario ? `${horario[1].slice(0,2)}:${horario[1].slice(2,4)}:${horario[1].slice(4,6)}` : 'N/A';\n\n    return [{\n      json: {\n        status: 'Sucesso',\n        data: dataISO,\n        dataFormatada,\n        arquivo: ultimo,\n        totalArquivos: encontrados.length,\n        horarioGeracao: horaStr,\n        detalhes: `Arquivo DPM gerado às ${horaStr} (${encontrados.length} arquivo(s) no dia)`,\n        pastaAcessivel: true\n      }\n    }];\n  }\n\n  return [{\n    json: {\n      status: 'Erro',\n      data: dataISO,\n      dataFormatada,\n      arquivo: null,\n      totalArquivos: 0,\n      horarioGeracao: null,\n      detalhes: `Arquivo DPM NÃO encontrado para ${dataFormatada}`,\n      pastaAcessivel: true\n    }\n  }];\n\n} catch (e) {\n  return [{\n    json: {\n      status: 'Erro',\n      data: dataISO,\n      dataFormatada,\n      arquivo: null,\n      totalArquivos: 0,\n      horarioGeracao: null,\n      detalhes: `Erro ao acessar pasta DPM: ${e.message}`,\n      pastaAcessivel: false\n    }\n  }];\n}"
      },
      "id": "verificar-arquivo",
      "name": "🔍 Verificar arquivo DPM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [480, 300]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "check-status",
              "leftValue": "={{ $json.status }}",
              "rightValue": "Sucesso",
              "operator": {
                "type": "string",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "verificar-resultado",
      "name": "📂 DPM gerou?",
