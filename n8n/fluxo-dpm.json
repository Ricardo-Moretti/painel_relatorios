        "html": "=<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n  <div style=\"background: linear-gradient(135deg, #ef4444, #f97316); padding: 28px 32px; border-radius: 16px 16px 0 0;\">\n    <h2 style=\"color: white; margin: 0; font-size: 22px;\">🔴 DPM — FALHA</h2>\n    <p style=\"color: rgba(255,255,255,0.8); margin: 6px 0 0; font-size: 14px;\">Verificação automática — n8n</p>\n  </div>\n  <div style=\"background: #ffffff; padding: 28px 32px; border: 1px solid #e2e8f0; border-top: none;\">\n    <p style=\"font-size: 16px; color: #1e293b; margin: 0 0 20px;\">O arquivo DPM <strong style=\"color: #ef4444;\">NÃO foi encontrado</strong> para a data de referência.</p>\n    <table style=\"width: 100%; border-collapse: collapse;\">\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Data referência</td><td style=\"padding: 12px 0; font-weight: 700; font-size: 14px; text-align: right; color: #ef4444;\">{{ $('🔍 Verificar arquivo DPM').item.json.dataFormatada }}</td></tr>\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Detalhes</td><td style=\"padding: 12px 0; font-size: 14px; text-align: right;\">{{ $('🔍 Verificar arquivo DPM').item.json.detalhes }}</td></tr>\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Pasta acessível</td><td style=\"padding: 12px 0; font-size: 14px; text-align: right;\">{{ $('🔍 Verificar arquivo DPM').item.json.pastaAcessivel ? 'Sim' : 'NÃO — verificar rede' }}</td></tr>\n      <tr><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Verificado em</td><td style=\"padding: 12px 0; font-size: 14px; text-align: right;\">{{ new Date().toLocaleString('pt-BR') }}</td></tr>\n    </table>\n    <div style=\"background: #fef2f2; border-left: 4px solid #ef4444; padding: 16px; margin-top: 20px; border-radius: 0 8px 8px 0;\">\n      <p style=\"color: #ef4444; font-weight: 700; margin: 0; font-size: 14px;\">⚠️ Ação necessária</p>\n      <p style=\"color: #7f1d1d; margin: 6px 0 0; font-size: 13px;\">Verifique o servidor DPM (192.168.109.228) e o agendamento da rotina das 23h.</p>\n    </div>\n  </div>\n  <div style=\"background: #f8f9fc; padding: 16px 32px; border-radius: 0 0 16px 16px; border: 1px solid #e2e8f0; border-top: none;\">\n    <p style=\"font-size: 11px; color: #94a3b8; margin: 0; text-align: center;\">Painel de Rotinas — Verificação automática via n8n</p>\n  </div>\n</div>"
      },
