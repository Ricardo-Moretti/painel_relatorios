      "typeVersion": 2,
      "position": [720, 300]
    },
    {
      "parameters": {
        "fromEmail": "painel-rotinas@tracbel.com.br",
        "toEmail": "ricardo.moretti@tracbel.com.br, hugo.rocha@tracbel.com.br, athaide.matos@tracbel.com.br",
        "subject": "=✅ DPM - Arquivo gerado com sucesso ({{ $('🔍 Verificar arquivo DPM').item.json.dataFormatada }})",
        "emailType": "html",
        "html": "=<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 600px; margin: 0 auto;\">\n  <div style=\"background: linear-gradient(135deg, #16a34a, #22d3ee); padding: 28px 32px; border-radius: 16px 16px 0 0;\">\n    <h2 style=\"color: white; margin: 0; font-size: 22px;\">✅ DPM — Gerado com Sucesso</h2>\n    <p style=\"color: rgba(255,255,255,0.8); margin: 6px 0 0; font-size: 14px;\">Verificação automática — n8n</p>\n  </div>\n  <div style=\"background: #ffffff; padding: 28px 32px; border: 1px solid #e2e8f0; border-top: none;\">\n    <p style=\"font-size: 16px; color: #1e293b; margin: 0 0 20px;\">O arquivo DPM foi <strong style=\"color: #16a34a;\">gerado com sucesso</strong>.</p>\n    <table style=\"width: 100%; border-collapse: collapse;\">\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Data referência</td><td style=\"padding: 12px 0; font-weight: 700; font-size: 14px; text-align: right;\">{{ $('🔍 Verificar arquivo DPM').item.json.dataFormatada }}</td></tr>\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Arquivo</td><td style=\"padding: 12px 0; font-weight: 700; font-size: 13px; text-align: right; font-family: monospace;\">{{ $('🔍 Verificar arquivo DPM').item.json.arquivo }}</td></tr>\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Horário geração</td><td style=\"padding: 12px 0; font-weight: 700; font-size: 14px; text-align: right;\">{{ $('🔍 Verificar arquivo DPM').item.json.horarioGeracao }}</td></tr>\n      <tr style=\"border-bottom: 1px solid #f1f5f9;\"><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Qtd arquivos no dia</td><td style=\"padding: 12px 0; font-weight: 700; font-size: 14px; text-align: right;\">{{ $('🔍 Verificar arquivo DPM').item.json.totalArquivos }}</td></tr>\n      <tr><td style=\"padding: 12px 0; color: #64748b; font-size: 14px;\">Verificado em</td><td style=\"padding: 12px 0; font-size: 14px; text-align: right;\">{{ new Date().toLocaleString('pt-BR') }}</td></tr>\n    </table>\n  </div>\n  <div style=\"background: #f8f9fc; padding: 16px 32px; border-radius: 0 0 16px 16px; border: 1px solid #e2e8f0; border-top: none;\">\n    <p style=\"font-size: 11px; color: #94a3b8; margin: 0; text-align: center;\">Painel de Rotinas — Verificação automática via n8n</p>\n  </div>\n</div>"
      },
